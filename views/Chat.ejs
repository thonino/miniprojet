<!DOCTYPE html>
<html lang="en">
  <head>
      <meta charset="UTF-8">
      <link rel="shortcut icon" href="/image" type="image/x-icon">
      <%- include('partials/_bootstrap.ejs') %>
      <title>chat</title>
  </head>
  <body>
    <%- include('partials/_nav.ejs') %> <!--Importer Nav-->
    <div class="container mt-5">
      <h1 class="mb-2 text-info">Page admin</h1>
      <h1 class="mb-2 text-info">Liste de tous les messages</h1>
        <table class="table">
          <thead>
            <tr>
              <th scope="col">Id</th>
              <th scope="col">expéditeur</th>
              <th scope="col">déstinataire</th>
              <th scope="col">Message</th>
              <!-- <th scope="col">Mettre à jour</th> -->
              <th scope="col">Supprimer</th>
            </tr>
          </thead>
          <tbody>
            <% data.forEach((chat)=>{%>
            <tr>
              <th scope="row"><%= chat.id %></th>
              <td><%= chat.expediteur %></td>
              <td><%= chat.destinataire %></td>
              <td><%= chat.message %></td>
              <!-- <td><a href="/chat/<%= //chat.id %>" class="btn btn-warning mb-2">Modifier</a></td> -->
              <td>
                <form method="post" action="/delete/<%= chat.id%>?_method=DELETE">
                  <input type="hidden" name="_method" value="DELETE">
                    <input type="submit" class="btn btn-danger mt-2" name="delete" value="Supprimer">
                </form>
            </td>
            </tr>
            <% })%>
          </tbody>
        </table>
    </div>
  </body>
</html>