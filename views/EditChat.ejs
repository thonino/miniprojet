<!DOCTYPE html>
<html lang="en">
  <head>
      <meta charset="UTF-8">
      <link rel="shortcut icon" href="/image" type="image/x-icon">
      <%- include('partials/_bootstrap.ejs') %>
      <title>Edit</title>
  </head>
  <body>
    <%- include('partials/_nav.ejs') %> <!--Importer Nav-->
    <div class="container mt-5">
        <div class="container mt-5">
          <h1>Modifier</h1>
          <form method="post" action="/chat/edit/<%=data.id%>?_method=PUT"> 
            <input type="hidden" name="_method" value="PUT">
              <div class="mb-3">
                <label class="form-label">expediteur</label>
                <input type="text" class="form-control" name="expediteur" value="<%= data.expediteur%>">
              </div>
              <div class="mb-3">
                <label class="form-label">destinataire</label>
                <input type="text" class="form-control" name="destinataire"value="<%= data.destinataire%>">
              </div>
              <div class="form-group mb-3">
                <label>message</label>
                <textarea class="form-control" name="message" rows="3"><%= data.message%></textarea>
              </div>
              <button type="submit" class="btn btn-primary">Envoyer</button>
            </form>
            <form method="post" action="/delete/<%= data.id%>?_method=DELETE">
              <input type="hidden" name="_method" value="DELETE">
                <input type="submit" class="btn btn-danger mt-2" name="delete" value="Supprimer">
            </form>
        </div>
    </div>
  </body>
</html>